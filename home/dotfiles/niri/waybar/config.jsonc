{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 0,
    "margin-top": 4,
    "margin-left": 8,
    "margin-right": 8,

    "modules-left": ["niri/workspaces", "mpris"],
    "modules-center": ["niri/window"],
    "modules-right": ["cpu", "memory", "pulseaudio", "battery", "network", "niri/language", "clock", "tray"],

    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "",
            "default": ""
        }
    },

    "niri/window": {
        "max-length": 50,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": " $1",
            "(.*) - Google Chrome": " $1",
            "(.*) â€” Alacritty": " $1",
            "(.*) - Visual Studio Code": "َ°¨‍ $1",
            "(.+) (\\[\\d+/\\d+\\]) (\\d+x\\d+)": "َ°‹© $1 $2 $3"
        }
    },

    "niri/language": {
        "format": "َ°ŒŒ {short}"
    },

    "cpu": {
        "interval": 5,
        "format": "َ°»  {usage}%",
        "tooltip": true
    },

    "memory": {
        "interval": 10,
        "format": "َ°چ› {percentage}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
    },

    "clock": {
        "format": "َ°¥” {:%H:%M}",
        "format-alt": "َ°¥” {:%A, %B %d  %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں muted",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol"
    },

    "network": {
        "format-wifi": "َ°¤¨ {signalStrength}%",
        "format-ethernet": "َ°ˆ€ {ipaddr}",
        "format-disconnected": "َ°¤­ off",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ifname}: {ipaddr}/{cidr}"
    },

    "battery": {
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "mpris": {
        "format": "َ°‌ڑ {title} â€” {artist}",
        "format-paused": "َ°ڈ¤ {title} â€” {artist}",
        "format-stopped": "",
        "max-length": 40,
        "player-icons": {
            "spotify": "",
            "default": "َ°‌ڑ"
        },
        "status-icons": {
            "paused": "َ°ڈ¤",
            "playing": "َ°‌ڑ",
            "stopped": ""
        },
        "ignored-players": ["firefox", "brave"]
    }
}
